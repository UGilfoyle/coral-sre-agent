# ==========================================
# Coral SRE Agent — environment template
# ==========================================
# Copy to .env and fill in values. Never commit .env.

# Neon Postgres (server-side only — do NOT prefix with VITE_)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Optional: override JSONL data directory for Coral sources (absolute path)
# CORAL_DATA_DIR="/absolute/path/to/data"

# Optional: AES-256-GCM key for integration token vault (32+ bytes, base64 or hex)
# INTEGRATION_ENCRYPTION_KEY=""
